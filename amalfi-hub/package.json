{
  "name": "amalfi-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "node --check server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npx vitest run --coverage",
    "validate": "npm run validate:typecheck && npm run validate:lint && npm run validate:unit && npm run validate:build",
    "validate:typecheck": "npm run build",
    "validate:lint": "npm run lint",
    "validate:unit": "node -e \"console.log('No hub-local unit test files configured. Use npm run validate:deploy for the monorepo test gate.')\"",
    "validate:integration": "node -e \"console.log('No hub-local integration test files configured. Use npm run validate:deploy for the monorepo test gate.')\"",
    "validate:browser": "node -e \"console.log('No hub-local Playwright suite configured. Use ..\\\\amalfi-agents\\\\harnesses\\\\run-saturn-browser.ps1 for app browser checks.')\"",
    "validate:ui": "npm run validate:browser",
    "validate:build": "npm run build",
    "validate:full": "npm run validate",
    "validate:deploy": "cd .. && powershell -NoProfile -ExecutionPolicy Bypass -File .\\run_all_tests.ps1"
  },
  "dependencies": {
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "supertest": "^7.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.7"
  }
}
